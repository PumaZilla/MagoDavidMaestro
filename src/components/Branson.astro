---
export interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;

const t = {
  es: {
    kicker: 'El momento',
    lede: 'Un show que ovacionaron en el mar.',
    body: 'Durante temporadas he sido el mago residente de <em>Virgin Voyages</em>, actuando en el teatro principal de sus cruceros con aforos completos. Una noche, Sir Richard Branson, fundador de Virgin Group, subió a ver el show desde una butaca de la cuarta fila.',
    quote: '"One of the best shows I\'ve ever seen."',
    attribution: 'Sir Richard Branson',
    role: 'Fundador de Virgin Group',
    imageAlt: 'David Maestro posando con Sir Richard Branson entre bastidores del teatro de Virgin Voyages tras el show.',
  },
  en: {
    kicker: 'The moment',
    lede: 'A show that got its standing ovation at sea.',
    body: 'For seasons I have been the resident magician of <em>Virgin Voyages</em>, performing in the main theatre of their cruise ships to full houses. One night, Sir Richard Branson, founder of Virgin Group, walked in and sat down in the fourth row.',
    quote: '"One of the best shows I\'ve ever seen."',
    attribution: 'Sir Richard Branson',
    role: 'Founder of Virgin Group',
    imageAlt: 'David Maestro posing with Sir Richard Branson backstage at a Virgin Voyages theatre after the show.',
  },
}[lang];
---

<section class="branson" aria-labelledby="branson-title">
  <div class="branson-bg" aria-hidden="true"></div>
  <div class="container branson-grid">
    <figure class="branson-media reveal">
      <img
        src="/img/branson.jpg"
        alt={t.imageAlt}
        width="1800"
        height="2400"
        loading="lazy"
        decoding="async"
      />
      <figcaption class="branson-caption">
        <span class="branson-caption-dot" aria-hidden="true"></span>
        Virgin Voyages
      </figcaption>
    </figure>

    <div class="branson-text">
      <div class="kicker reveal">
        <span class="kicker-line"></span>
        <span>{t.kicker}</span>
      </div>

      <h2 id="branson-title" class="branson-lede reveal reveal-delay-1">{t.lede}</h2>

      <p class="branson-body reveal reveal-delay-2" set:html={t.body}></p>

      <blockquote class="branson-quote reveal reveal-delay-3">
        <p>{t.quote}</p>
        <footer>
          <span class="branson-attr">{t.attribution}</span>
          <span class="branson-role">{t.role}</span>
        </footer>
      </blockquote>
    </div>
  </div>
</section>

<style>
  .branson {
    position: relative;
    padding-block: var(--section-gap);
    overflow: hidden;
    isolation: isolate;
    background:
      linear-gradient(180deg,
        var(--surface-ink) 0%,
        transparent 4rem,
        transparent calc(100% - 4rem),
        var(--surface-ink) 100%),
      oklch(0.09 0.010 25);
  }

  .branson-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse at 80% 30%, color-mix(in oklch, var(--crimson-deep) 22%, transparent), transparent 55%),
      radial-gradient(ellipse at 15% 85%, color-mix(in oklch, var(--ember) 14%, transparent), transparent 60%);
    opacity: 0.65;
  }

  .branson-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: center;
  }

  @media (min-width: 900px) {
    .branson-grid {
      grid-template-columns: 5fr 6fr;
      gap: clamp(3rem, 6vw, 6rem);
    }
  }

  .branson-media {
    position: relative;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-raised);
    box-shadow: 0 40px 90px -30px oklch(0 0 0 / 0.6);
    margin: 0;
  }

  .branson-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 30%;
    filter: contrast(1.03) saturate(1.05);
    transition: transform 1200ms var(--ease-out-quart);
  }

  .branson-media:hover img {
    transform: scale(1.03);
  }

  .branson-caption {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-pill);
    background: color-mix(in oklch, var(--surface-ink) 82%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--ink-primary);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .branson-caption-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--crimson);
    box-shadow: 0 0 12px var(--crimson);
    flex-shrink: 0;
  }

  .branson-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .branson-lede {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink-primary);
    text-wrap: balance;
    max-width: 22ch;
  }

  .branson-body {
    color: var(--ink-body);
    max-width: 50ch;
    line-height: 1.6;
  }

  .branson-body :global(em) {
    font-style: italic;
    color: var(--crimson);
    font-weight: 500;
  }

  .branson-quote {
    margin: 1rem 0 0;
    padding: 1.75rem;
    border-radius: var(--radius-lg);
    background: color-mix(in oklch, var(--surface-raised) 88%, transparent);
    border: 1px solid var(--stroke-medium);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .branson-quote::before {
    content: '"';
    position: absolute;
    top: -0.2em;
    left: 0.6rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 6rem;
    line-height: 1;
    color: var(--crimson);
    opacity: 0.35;
    pointer-events: none;
  }

  .branson-quote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    line-height: 1.35;
    color: var(--ink-primary);
    letter-spacing: -0.01em;
    text-wrap: balance;
    position: relative;
    z-index: 1;
  }

  .branson-quote footer {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--stroke-soft);
  }

  .branson-attr {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--ink-primary);
  }

  .branson-role {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

</style>
