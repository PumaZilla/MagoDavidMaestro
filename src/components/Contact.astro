---
export interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;

const t = {
  es: {
    kicker: 'Contacto',
    title: 'Cuéntame tu evento.',
    lede: 'La forma más rápida es un mensaje directo. Suelo responder en menos de 24h.',
    whatsapp: 'Escribir por WhatsApp',
    whatsappHint: 'Respuesta rápida · +34 677 652 984',
    or: 'o rellena el formulario',
    fields: {
      name: 'Nombre',
      email: 'Email',
      type: 'Tipo de evento',
      typeOptions: ['Boda', 'Evento corporativo', 'Restaurante / coctel', 'Teatro / gala', 'Cumpleaños / privado', 'Otro'],
      date: 'Fecha del evento (aprox.)',
      message: 'Cuéntame más',
      messagePlaceholder: '¿Dónde es? ¿Cuántos asistentes? ¿Alguna referencia?',
      submit: 'Enviar mensaje',
    },
    formNote: 'Sin listas de correo, sin spam. Tus datos solo llegan a David.',
    channels: [
      { label: 'Email', value: 'info@magodavidmaestro.com', href: 'mailto:info@magodavidmaestro.com' },
      { label: 'Instagram', value: '@davidmaestromago', href: 'https://instagram.com/davidmaestromago' },
      { label: 'Facebook', value: 'David Maestro', href: 'https://facebook.com/davidmaestromago' },
      { label: 'Base', value: 'A Coruña · 15006', href: null },
    ],
    prefilled: 'Hola David, me interesa contratar un show. ¿Podemos hablar?',
  },
  en: {
    kicker: 'Contact',
    title: 'Tell me about your event.',
    lede: 'A direct message is the fastest route. Usually a reply within 24h.',
    whatsapp: 'Message on WhatsApp',
    whatsappHint: 'Quick reply · +34 677 652 984',
    or: 'or use the form',
    fields: {
      name: 'Name',
      email: 'Email',
      type: 'Event type',
      typeOptions: ['Wedding', 'Corporate event', 'Restaurant / cocktail', 'Theatre / gala', 'Birthday / private', 'Other'],
      date: 'Event date (approx.)',
      message: 'Tell me more',
      messagePlaceholder: 'Where? How many guests? Any references?',
      submit: 'Send message',
    },
    formNote: 'No mailing lists, no spam. Your details reach David only.',
    channels: [
      { label: 'Email', value: 'info@magodavidmaestro.com', href: 'mailto:info@magodavidmaestro.com' },
      { label: 'Instagram', value: '@davidmaestromago', href: 'https://instagram.com/davidmaestromago' },
      { label: 'Facebook', value: 'David Maestro', href: 'https://facebook.com/davidmaestromago' },
      { label: 'Based in', value: 'A Coruña · 15006', href: null },
    ],
    prefilled: 'Hi David, I would like to book you for a show. Can we talk?',
  },
}[lang];

const whatsappHref = `https://wa.me/34677652984?text=${encodeURIComponent(t.prefilled)}`;
---

<section class="contact section" id="contacto" aria-labelledby="contact-title">
  <div class="contact-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="contact-grid">
      <div class="contact-intro">
        <div class="kicker reveal">
          <span class="kicker-line"></span>
          <span>{t.kicker}</span>
        </div>
        <h2 id="contact-title" class="contact-title reveal reveal-delay-1">
          {t.title.split(' ').slice(0, -1).join(' ')} <em>{t.title.split(' ').slice(-1)[0]}</em>
        </h2>
        <p class="contact-lede reveal reveal-delay-2">{t.lede}</p>

        <a href={whatsappHref} class="contact-whatsapp reveal reveal-delay-3" data-magnetic target="_blank" rel="noopener">
          <span class="contact-whatsapp-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
              <path d="M20.5 3.5A11.9 11.9 0 0 0 12 0a12 12 0 0 0-10.4 18L0 24l6.2-1.6A12 12 0 1 0 20.5 3.5zM12 21.9c-1.9 0-3.7-.5-5.3-1.5l-.4-.2-3.7 1 1-3.6-.2-.4A9.9 9.9 0 1 1 12 21.9zm5.4-7.4c-.3-.1-1.8-.9-2-1s-.5-.1-.7.2-.8 1-1 1.2-.4.2-.7 0a8 8 0 0 1-4-3.5c-.3-.5.3-.5.9-1.5.1-.2 0-.4 0-.5s-.7-1.7-.9-2.3-.5-.5-.7-.5H7.5c-.2 0-.5.1-.8.4a2.9 2.9 0 0 0-.9 2.1 5 5 0 0 0 1 2.7 11.5 11.5 0 0 0 4.4 4c2 1 2 .7 2.5.6a2.6 2.6 0 0 0 1.7-1.2 2 2 0 0 0 .1-1.2c-.1-.1-.2-.2-.5-.3z"/>
            </svg>
          </span>
          <span class="contact-whatsapp-content">
            <span class="contact-whatsapp-label">{t.whatsapp}</span>
            <span class="contact-whatsapp-hint">{t.whatsappHint}</span>
          </span>
          <span class="contact-whatsapp-arrow" aria-hidden="true">→</span>
        </a>

        <div class="contact-channels reveal reveal-delay-4">
          {t.channels.map((c, i) => (
            c.href ? (
              <a
                href={c.href}
                class={`contact-channel${i === 0 ? ' contact-channel-wide' : ''}`}
                target={c.href.startsWith('http') ? '_blank' : undefined}
                rel="noopener"
              >
                <span class="contact-channel-label">{c.label}</span>
                <span class="contact-channel-value">{c.value}</span>
              </a>
            ) : (
              <div class={`contact-channel is-static${i === 0 ? ' contact-channel-wide' : ''}`}>
                <span class="contact-channel-label">{c.label}</span>
                <span class="contact-channel-value">{c.value}</span>
              </div>
            )
          ))}
        </div>
      </div>

      <div class="contact-form-wrap reveal reveal-delay-2">
        <p class="contact-or" aria-hidden="true">
          <span></span><em>{t.or}</em><span></span>
        </p>
        <form
          class="contact-form"
          action="https://formsubmit.co/159aa142dd6a0a2f95e58bec1e8714d0"
          method="POST"
          autocomplete="on"
        >
          <input type="hidden" name="_subject" value={lang === 'es' ? 'Nuevo mensaje desde magodavidmaestro.com' : 'New message from magodavidmaestro.com'} />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_next" value={`https://magodavidmaestro.com${lang === 'es' ? '/es' : ''}/gracias/`} />
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="field">
            <label for="c-name">{t.fields.name}</label>
            <input id="c-name" name="name" type="text" required autocomplete="name" />
          </div>

          <div class="field">
            <label for="c-email">{t.fields.email}</label>
            <input id="c-email" name="email" type="email" required autocomplete="email" />
          </div>

          <div class="field">
            <label for="c-type">{t.fields.type}</label>
            <div class="select-wrap">
              <select id="c-type" name="tipo" required>
                <option value="" disabled selected></option>
                {t.fields.typeOptions.map((o) => <option value={o}>{o}</option>)}
              </select>
              <span aria-hidden="true">▾</span>
            </div>
          </div>

          <div class="field">
            <label for="c-date">{t.fields.date}</label>
            <input id="c-date" name="fecha" type="date" />
          </div>

          <div class="field field-full">
            <label for="c-message">{t.fields.message}</label>
            <textarea id="c-message" name="mensaje" rows="4" required placeholder={t.fields.messagePlaceholder}></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-icon-arrow contact-submit" data-magnetic>
            {t.fields.submit}
          </button>

          <p class="contact-form-note">{t.formNote}</p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: oklch(0.06 0.010 25);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .contact-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, oklch(0.06 0.010 25) 0%, transparent 20%, transparent 80%, oklch(0.06 0.010 25) 100%),
      url('/img/textures/stage.webp') center / cover no-repeat;
    z-index: -1;
    opacity: 0.55;
  }

  .contact-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 80%, color-mix(in oklch, var(--crimson-deep) 22%, transparent), transparent 55%),
      radial-gradient(circle at 80% 20%, color-mix(in oklch, var(--ember) 12%, transparent), transparent 55%);
    mix-blend-mode: screen;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }

  .contact-intro {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.035em;
    color: var(--ink-primary);
    text-wrap: balance;
  }

  .contact-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--crimson);
  }

  .contact-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.3rem;
    line-height: 1.4;
    color: var(--ink-body);
    max-width: 40ch;
  }

  .contact-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: var(--crimson);
    color: var(--ink-primary);
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-lg);
    width: fit-content;
    margin-top: 1rem;
    box-shadow: 0 20px 60px -20px var(--crimson);
    transition: transform var(--dur-fast) var(--ease-out-quart), background-color var(--dur-fast), box-shadow var(--dur-med);
  }

  .contact-whatsapp:hover {
    background: var(--crimson-hot);
    box-shadow: 0 25px 70px -15px var(--crimson-hot);
  }

  .contact-whatsapp-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: color-mix(in oklch, var(--ink-primary) 15%, transparent);
    flex-shrink: 0;
  }

  .contact-whatsapp-content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .contact-whatsapp-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .contact-whatsapp-hint {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.75rem;
    color: color-mix(in oklch, var(--ink-primary) 80%, transparent);
    letter-spacing: 0.02em;
  }

  .contact-whatsapp-arrow {
    margin-left: 0.5rem;
    transition: transform var(--dur-fast) var(--ease-out-quart);
    font-size: 1.2rem;
  }

  .contact-whatsapp:hover .contact-whatsapp-arrow {
    transform: translateX(5px);
  }

  .contact-channels {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--stroke-soft);
  }

  .contact-channel-wide {
    grid-column: 1 / -1;
  }

  @media (max-width: 640px) {
    .contact-channels { grid-template-columns: 1fr; }
  }

  .contact-channel {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--stroke-soft);
    border-radius: var(--radius-md);
    background: color-mix(in oklch, var(--surface-raised) 45%, transparent);
    transition: border-color var(--dur-fast), background-color var(--dur-fast);
  }

  .contact-channel:not(.is-static):hover {
    border-color: var(--crimson);
    background: color-mix(in oklch, var(--surface-raised) 70%, transparent);
  }

  .contact-channel-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-quiet);
  }

  .contact-channel-value {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--ink-primary);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .contact-form-wrap {
    background: color-mix(in oklch, var(--surface-raised) 92%, transparent);
    border: 1px solid var(--stroke-soft);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    backdrop-filter: blur(10px);
  }

  .contact-or {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-quiet);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .contact-or span {
    flex: 1;
    height: 1px;
    background: var(--stroke-soft);
  }

  .contact-form {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .contact-form {
      grid-template-columns: 1fr 1fr;
    }
    .field-full { grid-column: 1 / -1; }
    .contact-submit { grid-column: 1 / -1; justify-self: start; }
    .contact-form-note { grid-column: 1 / -1; }
  }

  @media (max-width: 639px) {
    .field input[type="date"] {
      font-size: 0.9rem;
      padding: 0.75rem 0.85rem;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  .field label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .field input,
  .field textarea,
  .field select {
    background: color-mix(in oklch, var(--surface-ink) 60%, transparent);
    border: 1px solid var(--stroke-soft);
    border-radius: var(--radius-md);
    padding: 0.85rem 1rem;
    color: var(--ink-primary);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color var(--dur-fast), background-color var(--dur-fast), box-shadow var(--dur-fast);
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--ink-quiet);
    font-family: var(--font-display);
    font-style: italic;
  }

  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    outline: none;
    border-color: var(--crimson);
    background: color-mix(in oklch, var(--surface-ink) 40%, transparent);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }

  .field textarea {
    resize: vertical;
    min-height: 100px;
  }

  .select-wrap {
    position: relative;
  }

  .select-wrap select {
    appearance: none;
    padding-right: 2.5rem;
    cursor: pointer;
  }

  .select-wrap span {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-muted);
    pointer-events: none;
  }

  input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(0.7);
    cursor: pointer;
  }

  .contact-submit {
    margin-top: 0.5rem;
  }

  .contact-form-note {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--ink-quiet);
    margin-top: 0.75rem;
  }
</style>
