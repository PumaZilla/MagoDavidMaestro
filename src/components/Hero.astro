---
export interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;

const t = {
  es: {
    eyebrow: 'Ilusionista · Mentalista · Prestidigitador · Showman',
    firstName: 'David',
    lastName: 'Maestro',
    tagline: 'Ilusionista',
    role: 'Magia de escena · Magia de cerca',
    lead: 'La magia no te engaña—te muestra que el asombro sigue vivo.',
    ctaPrimary: 'Reservar un show',
    ctaSecondary: 'Ver trailers',
    marquee: ['Escena', 'Cerca', 'Televisión', 'Cruceros', 'Teatros', 'Corporativo', 'Bodas', 'Restaurantes'],
    scroll: 'Scroll',
    heroAlt: 'David Maestro mezclando una baraja de cartas bajo focos de escena.',
  },
  en: {
    eyebrow: 'Illusionist · Mentalist · Sleight of Hand Artist · Showman',
    firstName: 'David',
    lastName: 'Maestro',
    tagline: 'Illusionist',
    role: 'Stage magic · Close-up magic',
    lead: 'Magic doesn\'t fool you—it shows you wonder still exists.',
    ctaPrimary: 'Book a show',
    ctaSecondary: 'Watch the trailers',
    marquee: ['Stage', 'Close-up', 'Television', 'Cruises', 'Theatres', 'Corporate', 'Weddings', 'Restaurants'],
    scroll: 'Scroll',
    heroAlt: 'David Maestro fanning a deck of cards under stage lights.',
  },
}[lang];
---

<section class="hero" aria-label="Hero">
  <div class="hero-media">
    <picture>
      <source srcset="/img/hero.webp" type="image/webp" />
      <img
        src="/img/hero.jpg"
        alt={t.heroAlt}
        width="1440"
        height="2160"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="hero-glow hero-glow-red" aria-hidden="true"></div>
    <div class="hero-glow hero-glow-teal" aria-hidden="true"></div>
    <div class="hero-vignette" aria-hidden="true"></div>
  </div>

  <div class="hero-inner container">
    <div class="hero-eyebrow reveal reveal-delay-1">
      <span class="hero-eyebrow-dot" aria-hidden="true"></span>
      <span>{t.eyebrow}</span>
    </div>

    <h1 class="hero-title">
      <span class="hero-first">
        {t.firstName.split('').map((ch) => <span class="ch">{ch}</span>)}
      </span>
      <span class="hero-last">
        {t.lastName.split('').map((ch) => <span class="ch">{ch}</span>)}
      </span>
    </h1>

    <div class="hero-meta reveal reveal-delay-4">
      <p class="hero-role">
        <span>{t.role}</span>
      </p>
      <p class="hero-lead">{t.lead}</p>
    </div>

    <div class="hero-cta reveal reveal-delay-5">
      <a href="#contacto" class="btn btn-primary btn-icon-arrow" data-magnetic>{t.ctaPrimary}</a>
      <a href="#reel" class="btn btn-ghost">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polygon points="6 4 20 12 6 20 6 4" fill="currentColor"/>
        </svg>
        {t.ctaSecondary}
      </a>
    </div>

    <div class="hero-marquee reveal reveal-delay-5" aria-hidden="true">
      <div class="hero-marquee-track">
        {[...t.marquee, ...t.marquee, ...t.marquee].map((w) => (
          <span class="hero-marquee-item">
            <span class="hero-marquee-dot"></span>
            {w}
          </span>
        ))}
      </div>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <span>{t.scroll}</span>
    <span class="hero-scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    padding-block: clamp(6rem, 12vh, 9rem) clamp(3rem, 6vh, 5rem);
    overflow: hidden;
    isolation: isolate;
    background: var(--surface-ink);
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .hero-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 70% 30%;
    filter: saturate(1.05) contrast(1.05) brightness(0.9);
    animation: heroKen 22s var(--ease-out-quart) infinite alternate;
    will-change: transform;
  }

  @keyframes heroKen {
    0% { transform: scale(1.05) translate(0, 0); }
    100% { transform: scale(1.15) translate(-2%, -1%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-media img { animation: none; transform: scale(1.05); }
  }

  .hero-media::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, color-mix(in oklch, var(--surface-ink) 60%, transparent) 0%, transparent 22%, transparent 55%, var(--surface-ink) 100%),
      linear-gradient(90deg, var(--surface-ink) 0%, color-mix(in oklch, var(--surface-ink) 70%, transparent) 32%, transparent 65%);
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 40%, transparent 30%, color-mix(in oklch, var(--surface-ink) 90%, transparent) 100%);
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .hero-glow-red {
    width: 60vmin;
    height: 60vmin;
    background: var(--crimson);
    left: -10vmin;
    bottom: -10vmin;
    animation: glowDrift 18s ease-in-out infinite alternate;
  }

  .hero-glow-teal {
    width: 45vmin;
    height: 45vmin;
    background: oklch(0.5 0.15 220);
    right: -5vmin;
    top: -10vmin;
    opacity: 0.22;
    animation: glowDrift 24s ease-in-out infinite alternate-reverse;
  }

  @keyframes glowDrift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(6vmin, -4vmin); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-glow-red, .hero-glow-teal { animation: none; }
  }

  .hero-inner {
    position: relative;
    display: grid;
    gap: clamp(1.25rem, 2vw, 2rem);
    max-width: var(--container);
    z-index: 1;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-muted);
    width: fit-content;
  }

  .hero-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--crimson);
    box-shadow: 0 0 12px var(--crimson);
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--type-mega);
    line-height: 0.82;
    letter-spacing: -0.05em;
    color: var(--ink-primary);
    display: flex;
    flex-direction: column;
    gap: 0.1em;
    text-wrap: nowrap;
  }

  .hero-first,
  .hero-last {
    display: flex;
    overflow: hidden;
    padding-block: 0.05em;
  }

  .hero-last {
    color: var(--crimson);
    margin-left: clamp(1.5rem, 4vw, 4rem);
  }

  .hero-title .ch {
    display: inline-block;
    transform: translateY(105%);
    animation: charIn 900ms var(--ease-out-expo) forwards;
    animation-delay: calc(var(--i, 0) * 40ms + 200ms);
  }

  .hero-first .ch:nth-child(1) { --i: 0; }
  .hero-first .ch:nth-child(2) { --i: 1; }
  .hero-first .ch:nth-child(3) { --i: 2; }
  .hero-first .ch:nth-child(4) { --i: 3; }
  .hero-first .ch:nth-child(5) { --i: 4; }
  .hero-last .ch:nth-child(1) { --i: 5; }
  .hero-last .ch:nth-child(2) { --i: 6; }
  .hero-last .ch:nth-child(3) { --i: 7; }
  .hero-last .ch:nth-child(4) { --i: 8; }
  .hero-last .ch:nth-child(5) { --i: 9; }
  .hero-last .ch:nth-child(6) { --i: 10; }
  .hero-last .ch:nth-child(7) { --i: 11; }

  @keyframes charIn {
    to { transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title .ch { animation: none; transform: none; }
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 34ch;
    margin-top: 0.5rem;
  }

  .hero-role {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .hero-role em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: var(--ink-primary);
  }

  .hero-lead {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.15rem, 1.5vw, 1.35rem);
    line-height: 1.4;
    color: var(--ink-body);
    max-width: 30ch;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .hero-marquee {
    margin-top: clamp(2rem, 4vw, 3rem);
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }

  .hero-marquee-track {
    display: flex;
    gap: 3rem;
    width: max-content;
    animation: marqueeSlide 32s linear infinite;
  }

  .hero-marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-quiet);
    white-space: nowrap;
  }

  .hero-marquee-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--crimson);
  }

  @keyframes marqueeSlide {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-marquee-track { animation: none; }
  }

  .hero-scroll {
    position: absolute;
    right: var(--gutter);
    bottom: 2.5rem;
    display: none;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-quiet);
    z-index: 2;
    writing-mode: vertical-rl;
  }

  .hero-scroll-line {
    display: block;
    width: 1px;
    height: 60px;
    background: linear-gradient(180deg, var(--stroke-soft), var(--crimson));
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%, 100% { transform: scaleY(1); transform-origin: top; }
    50% { transform: scaleY(0.4); transform-origin: top; }
  }

  @media (min-width: 900px) {
    .hero-scroll { display: inline-flex; }
  }

  /* Responsive layout tweaks
     ------------------------------------------------------------
     On small screens the wordmark sat on top of David's face and
     shoulders. Reframe the photo up so the figure lives in the
     upper half, drop a heavy vertical scrim so the lower half is
     nearly black, and give the type a soft shadow for insurance. */

  @media (max-width: 768px) {
    .hero {
      align-items: flex-end;
      padding-block: clamp(5.5rem, 14vh, 8rem) clamp(3rem, 6vh, 4.5rem);
    }

    .hero-media img {
      object-position: 55% 5%;
      filter: saturate(0.9) contrast(1.1) brightness(0.55);
    }

    /* Full-height scrim: photo shows through in the top third only,
       everything below the eyebrow line is progressively obsidian. */
    .hero-media::before {
      background:
        linear-gradient(
          180deg,
          color-mix(in oklch, var(--surface-ink) 55%, transparent) 0%,
          color-mix(in oklch, var(--surface-ink) 18%, transparent) 18%,
          color-mix(in oklch, var(--surface-ink) 60%, transparent) 34%,
          color-mix(in oklch, var(--surface-ink) 88%, transparent) 46%,
          var(--surface-ink) 60%
        );
    }

    .hero-vignette {
      background: radial-gradient(
        ellipse at 50% 18%,
        transparent 22%,
        color-mix(in oklch, var(--surface-ink) 94%, transparent) 90%
      );
    }

    .hero-glow-red {
      width: 90vmin;
      height: 90vmin;
      left: -20vmin;
      bottom: -30vmin;
      opacity: 0.22;
    }

    .hero-glow-teal { opacity: 0.12; }

    .hero-title {
      line-height: 0.9;
      text-shadow: 0 2px 24px color-mix(in oklch, var(--surface-ink) 75%, transparent);
    }

    .hero-last     { margin-left: 1.5rem; }
    .hero-eyebrow  { text-shadow: 0 1px 8px var(--surface-ink); }
    .hero-role,
    .hero-lead     { text-shadow: 0 1px 14px var(--surface-ink); }
    .hero-marquee  { text-shadow: 0 1px 8px var(--surface-ink); }
  }

  @media (max-width: 420px) {
    .hero-title { font-size: clamp(3.5rem, 18vw, 6rem); }
    .hero-media img { object-position: 55% 2%; }
    .hero-media::before {
      background:
        linear-gradient(
          180deg,
          color-mix(in oklch, var(--surface-ink) 60%, transparent) 0%,
          color-mix(in oklch, var(--surface-ink) 25%, transparent) 15%,
          color-mix(in oklch, var(--surface-ink) 70%, transparent) 30%,
          var(--surface-ink) 50%
        );
    }
  }
</style>
