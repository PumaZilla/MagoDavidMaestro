---
export interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;

const t = {
  es: {
    intro: 'Uso analíticas anónimas para saber qué contenidos funcionan y mejorar la web. Nada de publicidad ni de terceros.',
    more: 'Más información',
    href: '/es/legal/#cookies',
    accept: 'Aceptar',
    reject: 'Solo esenciales',
    label: 'Aviso de privacidad',
  },
  en: {
    intro: 'I use anonymous analytics to see what works and improve the site. No ads, no third parties.',
    more: 'Learn more',
    href: '/legal/#cookies',
    accept: 'Accept',
    reject: 'Only essential',
    label: 'Privacy notice',
  },
}[lang];
---

<aside
  class="cn"
  role="region"
  aria-label={t.label}
  hidden
  data-cn
>
  <div class="cn-inner">
    <p class="cn-copy">
      {t.intro}
      <a href={t.href} class="cn-link">{t.more}</a>
    </p>
    <div class="cn-actions">
      <button type="button" class="cn-btn cn-btn-ghost" data-cn-reject>
        {t.reject}
      </button>
      <button type="button" class="cn-btn cn-btn-primary" data-cn-accept>
        {t.accept}
      </button>
    </div>
  </div>
</aside>

<script is:inline>
  (function () {
    var banner = document.querySelector('[data-cn]');
    if (!banner) return;

    var stored = null;
    try {
      stored = localStorage.getItem('cookie-consent');
    } catch (e) {}

    if (!stored) {
      banner.hidden = false;
      requestAnimationFrame(function () {
        banner.classList.add('is-visible');
      });
    }

    function persist(value) {
      try {
        localStorage.setItem('cookie-consent', value);
      } catch (e) {}
    }

    function close() {
      banner.classList.remove('is-visible');
      setTimeout(function () {
        banner.hidden = true;
      }, 260);
    }

    var accept = banner.querySelector('[data-cn-accept]');
    var reject = banner.querySelector('[data-cn-reject]');

    if (accept) {
      accept.addEventListener('click', function () {
        persist('granted');
        if (typeof gtag === 'function') {
          gtag('consent', 'update', { analytics_storage: 'granted' });
        }
        close();
      });
    }
    if (reject) {
      reject.addEventListener('click', function () {
        persist('denied');
        if (typeof gtag === 'function') {
          gtag('consent', 'update', { analytics_storage: 'denied' });
        }
        close();
      });
    }
  })();
</script>

<style is:inline>
  .cn {
    position: fixed;
    left: 50%;
    bottom: 1.25rem;
    transform: translate(-50%, 130%);
    z-index: 100;
    width: min(calc(100vw - 2rem), 44rem);
    padding: 1rem 1.25rem;
    background: color-mix(in oklch, oklch(0.16 0.014 25) 92%, transparent);
    border: 1px solid oklch(1 0 0 / 0.13);
    border-radius: 1.25rem;
    box-shadow: 0 30px 80px -20px oklch(0 0 0 / 0.7);
    backdrop-filter: saturate(140%) blur(16px);
    -webkit-backdrop-filter: saturate(140%) blur(16px);
    opacity: 0;
    transition: transform 320ms cubic-bezier(0.25, 1, 0.5, 1), opacity 320ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .cn.is-visible {
    transform: translate(-50%, 0);
    opacity: 1;
  }

  .cn[hidden] { display: none; }

  .cn-inner {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: flex-start;
  }

  @media (min-width: 720px) {
    .cn-inner {
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }
  }

  .cn-copy {
    flex: 1;
    color: oklch(0.90 0.012 55);
    font-family: 'Manrope Variable', system-ui, sans-serif;
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
  }

  .cn-link {
    color: oklch(0.96 0.010 70);
    text-decoration: underline;
    text-decoration-color: oklch(0.57 0.208 27);
    text-underline-offset: 3px;
    transition: color 180ms;
    white-space: nowrap;
    margin-left: 0.25rem;
  }

  .cn-link:hover { color: oklch(0.57 0.208 27); }

  .cn-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .cn-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    font-family: 'Manrope Variable', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    line-height: 1;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background-color 180ms, border-color 180ms, color 180ms, transform 180ms;
    white-space: nowrap;
  }

  .cn-btn-primary {
    background: oklch(0.57 0.208 27);
    color: oklch(0.96 0.010 70);
  }

  .cn-btn-primary:hover {
    background: oklch(0.66 0.215 30);
  }

  .cn-btn-ghost {
    background: transparent;
    color: oklch(0.96 0.010 70);
    border-color: oklch(1 0 0 / 0.13);
  }

  .cn-btn-ghost:hover {
    background: color-mix(in oklch, oklch(0.19 0.016 25) 60%, transparent);
    border-color: oklch(1 0 0 / 0.18);
  }
</style>
