---
export interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;

const t = {
  es: {
    kicker: 'Apariciones en',
    lede: 'Televisión, cruceros internacionales, teatros y marcas que me han llamado a lo largo de los años.',
    venues: [
      'Virgin Voyages',
      'Got Talent España',
      'RTVE',
      'RTVG',
      'Clan TV',
      'Porsche',
      'Coca-Cola',
      'Teatro Rosalía',
      'Palacio de la Ópera',
      'NH Collection',
      'Meliá Hotels',
      'Inditex',
      'Estrella Galicia',
      'Abanca',
      'El Corte Inglés',
      'Deloitte',
      'Casino Atlántico',
    ],
  },
  en: {
    kicker: 'Appearances on',
    lede: 'Television, international cruise ships, theatres and brands that have called me over the years.',
    venues: [
      'Virgin Voyages',
      'Got Talent Spain',
      'RTVE',
      'RTVG',
      'Clan TV',
      'Porsche',
      'Coca-Cola',
      'Teatro Rosalía',
      'Palacio de la Ópera',
      'NH Collection',
      'Meliá Hotels',
      'Inditex',
      'Estrella Galicia',
      'Abanca',
      'El Corte Inglés',
      'Deloitte',
      'Casino Atlántico',
    ],
  },
}[lang];
---

<section class="venues" aria-labelledby="venues-title">
  <div class="container venues-inner">
    <header class="venues-header">
      <div class="kicker reveal">
        <span class="kicker-line"></span>
        <span id="venues-title">{t.kicker}</span>
      </div>
      <p class="venues-lede reveal reveal-delay-1">{t.lede}</p>
    </header>
  </div>

  <div class="venues-marquee-wrap">
    <div class="venues-marquee">
      <div class="venues-track">
        {[...t.venues, ...t.venues].map((v) => (
          <span class="venue-item">
            <span class="venue-dot" aria-hidden="true"></span>
            {v}
          </span>
        ))}
      </div>
    </div>
    <div class="venues-marquee venues-marquee-reverse">
      <div class="venues-track venues-track-reverse">
        {[...t.venues.slice().reverse(), ...t.venues.slice().reverse()].map((v) => (
          <span class="venue-item venue-item-quiet">
            <span class="venue-dot" aria-hidden="true"></span>
            {v}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .venues {
    padding-block: clamp(4rem, 8vw, 7rem);
    background: linear-gradient(
      180deg,
      var(--surface-ink) 0%,
      oklch(0.1 0.014 25) 30%,
      oklch(0.1 0.014 25) 70%,
      var(--surface-ink) 100%
    );
    overflow: hidden;
    position: relative;
  }

  .venues-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .venues-header {
    max-width: 45rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .venues-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.25rem, 1.8vw, 1.5rem);
    color: var(--ink-body);
    line-height: 1.4;
    max-width: 46ch;
  }

  .venues-marquee-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .venues-marquee {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 6%, black 94%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 6%, black 94%, transparent);
  }

  .venues-track {
    display: flex;
    gap: 3.5rem;
    width: max-content;
    animation: venuesSlide 48s linear infinite;
    padding-inline: 1.5rem;
  }

  .venues-track-reverse {
    animation: venuesSlideReverse 62s linear infinite;
  }

  .venues-marquee-reverse { opacity: 0.55; }

  @keyframes venuesSlide {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes venuesSlideReverse {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .venues-track { animation: none; flex-wrap: wrap; justify-content: center; }
  }

  .venue-item {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 3.2vw, 2.75rem);
    line-height: 1.2;
    color: var(--ink-primary);
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .venue-item-quiet {
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.25rem, 2.2vw, 1.85rem);
    color: var(--ink-muted);
  }

  .venue-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--crimson);
    flex-shrink: 0;
    box-shadow: 0 0 12px var(--crimson);
  }

  .venue-item-quiet .venue-dot {
    background: var(--ink-quiet);
    box-shadow: none;
    width: 4px;
    height: 4px;
  }

</style>
