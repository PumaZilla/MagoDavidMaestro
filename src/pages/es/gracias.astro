---
import Base from '../../layouts/Base.astro';
---

<Base title="Gracias · David Maestro" description="Mensaje enviado. David responderá pronto." lang="es" path="/es/gracias/">
  <main class="thanks">
    <div class="container-reading thanks-inner">
      <span class="thanks-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M8 12l3 3 5-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <h1 class="type-display">Mensaje enviado.</h1>
      <p class="type-body">Gracias por escribir. David suele responder en menos de 24 horas.</p>
      <a href="/es/" class="btn btn-primary btn-icon-arrow">Volver al inicio</a>
    </div>
  </main>

  <style>
    .thanks {
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 5rem 1.5rem;
      background: linear-gradient(180deg, var(--surface-ink), oklch(0.09 0.014 25));
    }

    .thanks-inner {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }

    .thanks-mark {
      color: var(--crimson);
      margin-bottom: 1rem;
    }

    .thanks .btn {
      margin-top: 1rem;
    }

    .thanks .type-body {
      max-width: 40ch;
      margin-inline: auto;
    }
  </style>
</Base>
